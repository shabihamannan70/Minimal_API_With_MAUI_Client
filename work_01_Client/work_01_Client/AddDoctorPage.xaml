<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="work_01_Client.AddDoctorPage"
             Title="AddDoctorPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Add Doctor Info" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,10" />

            <!-- Picture Selection -->
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Button Text="Select Picture" Clicked="SelectPicture_Clicked" BackgroundColor="#2196F3" TextColor="White" />
                <Image x:Name="DoctorImagePreview" WidthRequest="60" HeightRequest="60" Aspect="AspectFill" BackgroundColor="LightGray" />
            </HorizontalStackLayout>

            <Label Text="Doctor Name:" />
            <Entry x:Name="NameEntry" Placeholder="Enter doctor name" />

            <Label Text="Visiting Fee:" />
            <Entry x:Name="FeeEntry" Placeholder="Enter fee" Keyboard="Numeric" />

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="In Dhaka:" VerticalOptions="Center" />
                <Switch x:Name="InDhakaSwitch" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Appointments" FontSize="18" FontAttributes="Bold" />

            <!-- Appointment Entry Form -->
            <Frame BorderColor="LightGray" CornerRadius="8" Padding="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Patient Name:" />
                    <Entry x:Name="PatientNameEntry" Placeholder="Enter patient name" />

                    <Label Text="Patient Phone:" />
                    <Entry x:Name="PatientPhoneEntry" Placeholder="Enter patient phone" Keyboard="Telephone" />

                    <Label Text="Appointment Date:" />
                    <DatePicker x:Name="AppointmentDatePicker" />

                    <Button Text="Add to List" Clicked="AddAppointment_Clicked" BackgroundColor="#FF9800" TextColor="White" />
                </VerticalStackLayout>
            </Frame>

            <!-- Added Appointments List -->
            <CollectionView x:Name="AppointmentsCollection" HeightRequest="150" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,5" Padding="10" CornerRadius="5" BackgroundColor="#F5F5F5">
                            <VerticalStackLayout>
                                <Label Text="{Binding PatientName, StringFormat='Name: {0}'}" FontAttributes="Bold" />
                                <Label Text="{Binding Phone, StringFormat='Phone: {0}'}" />
                                <Label Text="{Binding AppointmentDate, StringFormat='Date: {0:d}'}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Save Doctor" Clicked="SaveButton_Clicked" BackgroundColor="#4CAF50" TextColor="White" Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>