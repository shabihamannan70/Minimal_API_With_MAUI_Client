<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:work_01_Client.DTOs"
             x:Class="work_01_Client.DoctorListPage"
             Title="DoctorListPage">
    <!--<ContentPage.Resources>
      <converters:Base64ToImageConverter x:Key="Base64ToImageConverter"></converters:Base64ToImageConverter>
    </ContentPage.Resources>-->
    <Grid RowDefinitions="auto, *" Padding="20">
        <Button Grid.Row="0" Text="Add New Doctor" Clicked="Button_Clicked"  Margin="0,0,0,15"
                BackgroundColor="#2196F3"
                TextColor="White"></Button>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Doctors}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" Padding="10" CornerRadius="8" BorderColor="LightGray">
                        <Grid ColumnDefinitions="*, auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="{Binding DoctorName}" FontAttributes="Bold" FontSize="18"/>
                                <Label Text="{Binding VisitingFee, StringFormat='Fee: {0:C}'}" FontSize="14"/>
                                <Label Text="{Binding InDhaka, StringFormat='In Dhaka: {0}'}" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>